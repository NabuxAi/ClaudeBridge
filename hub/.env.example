# ============================================================
# DigiWP Ai Support — hub configuration
# ------------------------------------------------------------
# The hub is only a front-end. Every action is proxied through
# YOUR server (the "واسط"). Point this at your server's API base.
# The hub never talks to a managed WordPress site directly.
# ============================================================

# Base URL of YOUR server's API (the only backend the hub talks to).
VITE_API_BASE_URL=https://api.digiwp.example/v1

# Optional: set to "1" to run the hub against built-in mock data
# (no server needed) so you can preview all screens offline.
VITE_USE_MOCK=1
