# DigiWP server (the واسط) configuration
PORT=8787

# Secret for signing hub session tokens (CHANGE in production).
AUTH_SECRET=dev-only-change-me

# Allowed hub origin for CORS (the hub's URL). Use * only for local dev.
CORS_ORIGIN=http://localhost:5173

# Optional JSON file to persist sites + pairings across restarts.
# DATA_FILE=./data.json

# When 1, per-site reads/actions relay to the live connector on each paired site.
# Leave 0 to run the full demo with no real WordPress sites.
LIVE=0
